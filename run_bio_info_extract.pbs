#!/bin/bash
# ===================== PBS Resource Configuration (Do not modify) =====================
#PBS -N bio_info_extract
#PBS -q fat
#PBS -l nodes=node01.chess:ppn=200
#PBS -l walltime=100:00:00
#PBS -o /data7/sunxiuqiang/Detailed_Biometric_Information_Extraction/task_run.log
#PBS -e /data7/sunxiuqiang/Detailed_Biometric_Information_Extraction/task_error.log

set -euo pipefail

# ===================== Runtime Configuration =====================
PROJECT_DIR="/data7/sunxiuqiang/Detailed_Biometric_Information_Extraction"
INPUT_FILE="${PROJECT_DIR}/source_text_report.xlsx"
OUTPUT_DIR="${PROJECT_DIR}/out"

# 1. Activate py39 environment
source /data/homebackup/sunxiuqiang/tools/miniconda3/etc/profile.d/conda.sh
conda activate py39

# 2. Enter project directory
cd "${PROJECT_DIR}" || exit 1

# 3. Check input and main script
if [ ! -f "${INPUT_FILE}" ]; then
    echo "Error: Input file does not exist: ${INPUT_FILE}"
    exit 1
fi

if [ ! -f "${PROJECT_DIR}/main.py" ]; then
    echo "Error: main.py does not exist in project directory"
    exit 1
fi

mkdir -p "${OUTPUT_DIR}/logs"

echo "Running location-based outbreak extraction schema..."
echo "Output fields include: location, continent, country, province, original_location, original_country, imported_location, imported_country"

# 4. Run Python script (\ must be the LAST character of each line, NO SPACES AFTER \)
python main.py \
--input "${INPUT_FILE}" \
--output-excel "${OUTPUT_DIR}/biometric_extracted_result.xlsx" \
--output-csv "${OUTPUT_DIR}/biometric_extracted_result.csv" \
--log-file "${OUTPUT_DIR}/logs/pipeline.log" \
--endpoint "http://159.226.80.101:1045/v1/chat/completions" \
--model "DeepSeek-V3" \
--timeout-seconds 180 \
--max-retries 3 \
--request-interval-seconds 0.2 \
--limit 0

echo "Excel output: ${OUTPUT_DIR}/biometric_extracted_result.xlsx"
echo "CSV output: ${OUTPUT_DIR}/biometric_extracted_result.csv"
echo "Pipeline log: ${OUTPUT_DIR}/logs/pipeline.log"
echo "PBS job completed successfully."
